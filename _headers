# Cloudflare Pages response headers
# https://developers.cloudflare.com/pages/configuration/headers/
#
# This file is served verbatim from the deploy root, so it controls the
# headers on every response from the production origin. Keep it tight:
# any third-party origin added below is a new trust boundary.
#
# Four audits gate changes to this file (see plan Phase B):
#   1. Image sources — any new remote <img src="..."> origin must be
#      added to img-src, or the image mirrored to public/ first.
#   2. Form transport — any native <form action="..."> to a remote
#      origin must be added to form-action.
#   3. Inline scripts/styles — new inline scripts require moving them
#      to public/*.js so script-src stays 'self' without 'unsafe-inline'.
#   4. External fetches — any new fetch() target origin must be added
#      to connect-src.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://formsubmit.co https://script.google.com https://script.googleusercontent.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
